{
  "title": "Ecommerce Events Overview",
  "uid": "ecommerce-events",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "5s",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Uspesno rezervisani (per minut)",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(inventory_reserved_count_total[1m]) * 60",
          "legendFormat": "rezervisani/min"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Odbijeni - ukupno po razlogu",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "sum by(reason) (inventory_rejected_count_total)",
          "legendFormat": "{{reason}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "gauge",
      "title": "Outbox neobjavljeni redovi (lag)",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "outbox_pending_size",
          "legendFormat": "pending"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 200 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "HTTP zahtevi (POST /orders, p95 latencija)",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{uri=\"/orders\", method=\"POST\"}[1m])) by (le))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Rezervacije vs odbijeni (rate per second)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "rate(inventory_reserved_count_total[30s])",
          "legendFormat": "rezervisani/s"
        },
        {
          "expr": "sum by(reason) (rate(inventory_rejected_count_total[30s]))",
          "legendFormat": "odbijeni - {{reason}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Outbox lag tokom vremena",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "expr": "outbox_pending_size",
          "legendFormat": "neobjavljeno"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "JVM memorija po servisu",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{area=\"heap\"}",
          "legendFormat": "{{service}} - {{id}}"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Kafka consumer lag (Kafka client metrika)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "expr": "kafka_consumer_fetch_manager_records_lag_max",
          "legendFormat": "{{service}} - {{topic}}"
        }
      ]
    }
  ]
}
