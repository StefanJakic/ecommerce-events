<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <springProperty scope="context" name="serviceName" source="spring.application.name"/>

    <!--
      JSON logging - svako polje je posebno, pretrazivanje preko Loki/ELK je trivijalno.
      MDC polja koja se ocekuju:
        traceId, spanId  - postavlja Micrometer Tracing automatski
        orderId          - poslovni identifikator
        eventId          - identifikator konkretnog event-a (za debug duplikata)
        eventType        - "OrderCreated", "InventoryReserved", itd.
        status           - "CREATED", "CONFIRMED", "REJECTED"
    -->
    <appender name="JSON" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LoggingEventCompositeJsonEncoder">
            <providers>
                <timestamp>
                    <fieldName>time</fieldName>
                    <pattern>yyyy-MM-dd'T'HH:mm:ss.SSSXXX</pattern>
                    <timeZone>Europe/Belgrade</timeZone>
                </timestamp>
                <pattern>
                    <pattern>
                        {
                          "service": "${serviceName}",
                          "level": "%level",
                          "logger": "%logger{40}",
                          "thread": "%thread"
                        }
                    </pattern>
                </pattern>
                <mdc/>             <!-- ubaci sva MDC polja kao top-level kljuceve -->
                <message/>
                <stackTrace/>
            </providers>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="JSON"/>
    </root>

</configuration>
